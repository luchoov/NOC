# ============================================
# PostgreSQL
# ============================================
POSTGRES_DB=noc
POSTGRES_USER=noc_user
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# MinIO (S3-compatible media storage)
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=noc-media

# ============================================
# NOC Web (ASP.NET Core API)
# ============================================
NOC_WEB_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
NOC_PUBLIC_BASE_URL=https://your-noc-public.example.com

# ============================================
# JWT Authentication
# ============================================
# Secret key for signing JWTs — minimum 32 characters
JWT_SECRET=changeme_jwt_secret_min_32_chars_long_here
JWT_ISSUER=noc-api
JWT_AUDIENCE=noc-clients
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ============================================
# Encryption (AES-256-GCM for provider secrets)
# ============================================
# Base64-encoded 32-byte key. Generate with:
#   openssl rand -base64 32
ENCRYPTION_MASTER_KEY=changeme_base64_256bit_key_here

# ============================================
# Evolution API (already deployed externally)
# ============================================
EVOLUTION_API_URL=https://your-evolution-api.example.com
EVOLUTION_API_KEY=changeme_evolution_api_key

# ============================================
# Worker Configuration
# ============================================
MESSAGING_CONSUMER_COUNT=4
REOPEN_WINDOW_HOURS=24
CAMPAIGNS_BATCH_SIZE=50
CAMPAIGNS_LEASE_MINUTES=5
CAMPAIGNS_MSGS_PER_MINUTE=10
CAMPAIGNS_BAN_THRESHOLD_RATIO=0.4
CAMPAIGNS_BAN_MIN_FAILURES=5

# ============================================
# Alerts / Notifications
# ============================================
SLACK_WEBHOOK_URL=
ADMIN_EMAIL=

# ============================================
# Frontend
# ============================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
